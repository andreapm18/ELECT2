@using Microsoft.AspNetCore.Http
@model List<Inventory.Models.Database.InventoryItem>

@{
    ViewData["Title"] = "Inventory";
    int totalPages = (int)Math.Ceiling((double)ViewBag.TotalItems / ViewBag.PageSize);
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>My Inventory</h2>
    <div>
        <span class="me-3">Hello, @(Context.Session.GetString("Username"))</span>
        <a asp-controller="Account" asp-action="Logout" class="btn btn-danger">Logout</a>
    </div>
</div>

@if (TempData["Error"] != null)
{
        <div class="alert alert-danger">@TempData["Error"]</div>
}

@if (TempData["Success"] != null)
{
        <div class="alert alert-success">@TempData["Success"]</div>
}

<form method="get" class="mb-3">
    <input name="search" value="@ViewBag.Search" class="form-control" placeholder="Search item" />
</form>

<button class="btn btn-primary mb-3" data-bs-toggle="modal" data-bs-target="#addModal">
    Add Item
</button>

@if (Model.Count == 0)
{
        <div class="alert alert-info">No Items Available</div>
}
else
{
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Item Name</th>
                    <th>Quantity</th>
                    <th>Price</th>
                    <th>Date Added</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                        <tr>
                            <td>@item.ItemName</td>
                            <td>@item.Quantity</td>
                            <td>@item.Price</td>
                            <td>@item.DateAdded</td>
                            <td>
                                <button class="btn btn-warning btn-sm" data-bs-toggle="modal" data-bs-target="#editModal-@item.Id">
                                    Edit
                                </button>

                                <form method="post" asp-action="Delete" style="display:inline;">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Delete this item?')">Delete</button>
                                </form>
                            </td>
                        </tr>

                        <div class="modal fade" id="editModal-@item.Id" tabindex="-1">
                            <div class="modal-dialog">
                                <div class="modal-content">
                                    <form method="post" asp-action="Edit">
                                        <div class="modal-header">
                                            <h5>Edit Item</h5>
                                        </div>

                                        <div class="modal-body">
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <input name="itemName" class="form-control" value="@item.ItemName" placeholder="Item Name" />
                                            <input name="quantity" class="form-control mt-2" value="@item.Quantity" placeholder="Quantity" />
                                            <input name="price" class="form-control mt-2" value="@item.Price" placeholder="Price" />
                                        </div>

                                        <div class="modal-footer">
                                            <button type="submit" class="btn btn-primary">Update</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
            }
            </tbody>
        </table>
}

<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form method="post" asp-action="Create">
                <div class="modal-header">
                    <h5>Add Item</h5>
                </div>

                <div class="modal-body">
                    <input name="itemName" class="form-control" placeholder="Item Name" />
                    <input name="quantity" class="form-control mt-2" placeholder="Quantity" />
                    <input name="price" class="form-control mt-2" placeholder="Price" />
                </div>

                <div class="modal-footer">
                    <button type="submit" class="btn btn-primary">Save</button>
                </div>
            </form>
        </div>
    </div>
</div>

<nav>
    <ul class="pagination">
        @for (int i = 1; i <= totalPages; i++)
        {
                <li class="page-item @(ViewBag.Page == i ? "active" : "")">
                    <a class="page-link" href="?page=@i&search=@ViewBag.Search">@i</a>
                </li>
        }
    </ul>
</nav>